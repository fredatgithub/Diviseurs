<Window x:Class="Diviseurs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Diviseurs"
        mc:Ignorable="d"
        Title="Calculateur de Diviseurs" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:BoolToOuiNonConverter x:Key="BoolToOuiNonConverter"/>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Nombre maxi:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtMaxNumber" Width="100" Height="25" VerticalContentAlignment="Center" Text="100"/>
            <Button x:Name="btnCalculate" Content="Calculer" Width="80" Height="25" Margin="10,0,10,0" Click="BtnCalculate_Click"/>
            <Label Content="Fichier CSV:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtFilePath" Width="200" Height="25" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
            <Button x:Name="btnSave" Content="Sauvegarder" Width="80" Height="25" Click="BtnSave_Click"/>
        </StackPanel>
        
        <DataGrid Grid.Row="2" x:Name="dgDivisors" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Number}" Width="80"/>
                <DataGridTextColumn Header="Diviseurs" Binding="{Binding Divisors}" Width="*"/>
                <DataGridTextColumn Header="Nombre de diviseurs" Binding="{Binding DivisorCount}" Width="150"/>
                <DataGridTextColumn Header="Est premier" Binding="{Binding IsPrime, Converter={StaticResource BoolToOuiNonConverter}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
